# ── Environment Configuration ─────────────────────────────────────────────────
# Copy this to .env and fill in your values (never commit .env to git)

# App
APP_NAME="Enterprise AI Support Automation Platform"
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_support_db

# Vector DB (FAISS)
FAISS_INDEX_PATH=./data/faiss_index
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
TOP_K_RESULTS=5

# LLM (leave blank for demo mode)
OPENAI_API_KEY=
LLM_MODEL=gpt-3.5-turbo
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2

# RAG
CHUNK_SIZE=600
CHUNK_OVERLAP=100
CONFIDENCE_THRESHOLD=0.65

# Escalation
ESCALATION_EMAIL=support-admin@enterprise.com

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AWS (production)
AWS_REGION=us-east-1
S3_BUCKET_NAME=enterprise-ai-support-docs
